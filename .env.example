# Ledger — Environment Variables
#
# Copy this file to `.env` and fill in real values.
# Every variable read by code appears here with a comment explaining what it is.
# This file is committed; `.env` is not.
#
# CI (.github/workflows/ci.yml) needs NO real secrets: lint/typecheck/build use
# dummy DATABASE_URL/DIRECT_URL (prisma generate only needs them defined, never
# connects) and a dummy ENCRYPTION_KEY; the test job points DATABASE_URL/DIRECT_URL
# at an ephemeral Postgres service container. Real values here are for local dev
# and (later) production only.

# =============================================================================
# Milestone A — Repo & tooling (current)
# =============================================================================
# No env vars consumed by app code yet.

# =============================================================================
# Milestone B — Database foundation (Prisma + Supabase)
# =============================================================================
# Find both connection strings at: Supabase dashboard → Project Settings →
# Database → Connection string. Use the "Transaction" tab for DATABASE_URL,
# "Session" tab (or "Direct connection" if shown) for DIRECT_URL.
# URL-encode the password if it contains @ : / ? # [ ] %.
DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-<N>-<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-<N>-<REGION>.pooler.supabase.com:5432/postgres"

# =============================================================================
# Milestone C — Observability (Pino + Sentry + PostHog + Better Stack)
# =============================================================================
# Sentry: project DSN — same value, server reads SENTRY_DSN, client reads NEXT_PUBLIC_SENTRY_DSN.
SENTRY_DSN="https://<key>@<org-id>.ingest.us.sentry.io/<project-id>"
NEXT_PUBLIC_SENTRY_DSN="https://<key>@<org-id>.ingest.us.sentry.io/<project-id>"
# Sourcemap upload (populated when Milestone C wires it; org/project slugs from Sentry dashboard URLs).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# PostHog: same key for client and server. Host: https://us.i.posthog.com or https://eu.i.posthog.com.
NEXT_PUBLIC_POSTHOG_KEY="phc_<rest of key>"
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
POSTHOG_PROJECT_API_KEY="phc_<rest of key>"

# Better Stack: source token for log ingestion.
BETTER_STACK_SOURCE_TOKEN="<source token>"

# =============================================================================
# Milestone D — Security primitives (AES-256-GCM + Upstash rate limit)
# =============================================================================
# 64 hex chars = 32 bytes for AES-256-GCM. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Rotation = generate a new key + re-encrypt every CanvasToken row.
ENCRYPTION_KEY="<64 hex chars>"

# Upstash Redis — backs the rate limiter (Milestone D). Get both from the
# Upstash console → your database → "REST API". Optional in development (the
# limiter fails open and logs a warning when absent); REQUIRED in production
# (the limiter throws at request time if missing, so prod can't run unprotected).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# =============================================================================
# Milestone E — Authentication (NextAuth + Resend magic link)
# =============================================================================
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="<32-byte base64 secret>"
NEXTAUTH_URL="http://localhost:3000"
RESEND_API_KEY="re_<rest of key>"
# Pre-verified-domain default; switch to login@ledger.app once Resend domain is set up.
RESEND_FROM_EMAIL="onboarding@resend.dev"

# =============================================================================
# Milestone E/F — Invite gate for Canvas token-paste (Phase 0)
# =============================================================================
# Consumed from Milestone E onward (onboarding step 2 gate). When INVITE_ONLY is
# not "true", everyone may paste; when "true", only allowlisted emails do —
# others see a "coming soon" panel.
INVITE_ONLY=true
INVITE_ALLOWLIST=        # Comma-separated emails permitted to paste Canvas tokens

# =============================================================================
# Misc
# =============================================================================
NODE_ENV="development"

# =============================================================================
# Milestone J — Production cutover (placeholders)
# =============================================================================
# AI_BUDGET_USD_DAILY=   # Anthropic spend ceiling. No AI usage in Phase 0; wired for Phase 1+.
