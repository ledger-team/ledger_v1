# Ledger — Environment Variables
#
# Copy this file to `.env` and fill in real values.
# Every variable read by code appears here with a comment explaining what it is.
# This file is committed; `.env` is not.
#
# Populated per milestone — currently no app code reads any of these. Sections below
# are placeholders for what each milestone will add.

# =============================================================================
# Milestone A — Repo & tooling (current)
# =============================================================================
# No env vars consumed by app code yet.

# =============================================================================
# Milestone B — Database foundation (Prisma + Supabase)
# =============================================================================
# DATABASE_URL=          # Supabase pooler connection (transaction mode)
# DIRECT_URL=            # Supabase direct connection (used for migrations only)

# =============================================================================
# Milestone C — Observability (Pino + Sentry + PostHog + Better Stack)
# =============================================================================
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# POSTHOG_PROJECT_API_KEY=
# BETTER_STACK_SOURCE_TOKEN=

# =============================================================================
# Milestone D — Security primitives (AES-256-GCM + Upstash rate limit)
# =============================================================================
# ENCRYPTION_KEY=        # 64 hex chars = 32 bytes for AES-256-GCM. Generate with: openssl rand -hex 32
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# =============================================================================
# Milestone E — Authentication (NextAuth + Resend magic link)
# =============================================================================
# NEXTAUTH_SECRET=       # Generate with: openssl rand -base64 32
# NEXTAUTH_URL=http://localhost:3000
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=login@ledger.app

# =============================================================================
# Milestone F — Canvas integration (invite-only token-paste in Phase 0)
# =============================================================================
# INVITE_ONLY=true       # Gates Canvas token paste UI to allowlisted emails only
# INVITE_ALLOWLIST=      # Comma-separated emails permitted to paste Canvas tokens

# =============================================================================
# Milestone J — Production cutover (placeholders)
# =============================================================================
# AI_BUDGET_USD_DAILY=   # Anthropic spend ceiling. No AI usage in Phase 0; wired for Phase 1+.
